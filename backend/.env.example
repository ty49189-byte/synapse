# ============================================================
# MeetLink Connect - Environment Configuration
# ============================================================

# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/meetlink
MONGODB_URI_PROD=mongodb+srv://user:password@cluster.mongodb.net/meetlink

# Redis (for session management & pub/sub)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# STUN/TURN Servers (WebRTC ICE)
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=turn:your-turn-server.com:3478
TURN_USERNAME=your_turn_username
TURN_PASSWORD=your_turn_password
# Free TURN servers (Metered.ca)
METERED_API_KEY=your_metered_api_key

# Mediasoup (SFU for large calls)
MEDIASOUP_WORKER_MIN=2
MEDIASOUP_WORKER_MAX=4
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=your_server_public_ip

# File Upload
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=./uploads
ALLOWED_DOC_TYPES=pdf,doc,docx,ppt,pptx,xls,xlsx,txt,png,jpg,jpeg,gif

# Recording Storage
RECORDING_DIR=./uploads/recordings
MAX_RECORDING_DURATION_MINS=180

# Translation API (Google Cloud / DeepL / LibreTranslate)
TRANSLATION_PROVIDER=google
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key
DEEPL_API_KEY=your_deepl_api_key
LIBRETRANSLATE_URL=https://libretranslate.com

# Speech-to-Text (Live Captions & Transcription)
STT_PROVIDER=google
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key
DEEPGRAM_API_KEY=your_deepgram_api_key
ASSEMBLY_AI_KEY=your_assemblyai_key

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=MeetLink <noreply@meetlink.com>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Session Config
SESSION_CLEANUP_INTERVAL_MINS=30
MAX_PARTICIPANTS_PER_ROOM=100
MAX_ROOMS_PER_USER=10
